# Google OAuth Client ID จาก https://console.cloud.google.com/apis/credentials
# (สร้าง OAuth 2.0 Client ID ชนิด Web application แล้วเพิ่ม origin ของ showcase ใน Authorized JavaScript origins)
# ถ้าไม่ตั้งค่า แอปจะใช้โหมด mock login อัตโนมัติ
VITE_GOOGLE_CLIENT_ID=

# Essie AI Chatbot backend URL (โปรเจค essie-ai-chatbot)
VITE_CHAT_API_URL=http://localhost:8000
